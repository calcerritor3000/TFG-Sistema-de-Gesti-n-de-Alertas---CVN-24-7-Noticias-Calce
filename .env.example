# Copia este archivo a .env y rellena los valores (nunca subas .env a GitHub)

# --- Servidor ---
PORT=4000
JWT_SECRET=genera_un_secreto_largo_y_aleatorio_aqui

# URL pública del frontend (para CORS). En producción: https://tu-dominio.com
FRONTEND_URL=http://localhost:3000

# URL pública del API (notificaciones push, enlaces en emails). En producción: https://tu-dominio.com
API_PUBLIC_URL=http://localhost:4000

# --- Base de datos MySQL (local o en la nube) ---
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=alertas_db

# Obligatorio en la mayoría de MySQL en la nube (Railway, Aiven, PlanetScale, etc.)
DB_SSL=false
# Si el proveedor usa certificado autofirmado: DB_SSL_REJECT_UNAUTHORIZED=false

# Admin por defecto (solo se crea si no existe)
ADMIN_DEFAULT_PASSWORD=admin123

# --- Notificaciones push (opcional) ---
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@tudominio.com

# --- Recuperación de contraseña (opcional) ---
# PASSWORD_RESET_LOG_LINK=true
